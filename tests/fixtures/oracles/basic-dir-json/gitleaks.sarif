{
 "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
 "version": "2.1.0",
 "runs": [
  {
   "tool": {
    "driver": {
     "name": "gitleaks",
     "semanticVersion": "v8.0.0",
     "informationUri": "https://github.com/gitleaks/gitleaks",
     "rules": [
      {
       "id": "oracle-token",
       "shortDescription": {
        "text": "Synthetic token used for oracle compatibility tests."
       }
      }
     ]
    }
   },
   "results": [
    {
     "message": {
      "text": "oracle-token has detected secret for file source.txt."
     },
     "ruleId": "oracle-token",
     "locations": [
      {
       "physicalLocation": {
        "artifactLocation": {
         "uri": "source.txt"
        },
        "region": {
         "startLine": 1,
         "startColumn": 16,
         "endLine": 1,
         "endColumn": 34,
         "snippet": {
          "text": "REDACTED"
         }
        }
       }
      }
     ],
     "partialFingerprints": {
      "commitSha": "",
      "email": "",
      "author": "",
      "date": "",
      "commitMessage": ""
     },
     "properties": {
      "tags": []
     }
    }
   ]
  }
 ]
}
