{
  "name": "picket-docs",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "docs:generate": "dotnet run --project ../tools/Picket.Docs/Picket.Docs.csproj",
    "docs:check": "dotnet run --project ../tools/Picket.Docs/Picket.Docs.csproj -- --check",
    "prebuild": "pnpm docs:generate",
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro build && astro preview"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/starlight": "0.41.3",
    "astro": "7.0.6",
    "sharp": "0.35.3"
  },
  "devDependencies": {}
}
