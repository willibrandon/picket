{
  "manifestVersion": 1,
  "id": "picket",
  "name": "Picket",
  "version": "0.1.3",
  "publisher": "willibrandon",
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "description": "Local-first secrets scanning for Azure Pipelines.",
  "categories": [
    "Azure Pipelines"
  ],
  "tags": [
    "DevSecOps",
    "secret scanning",
    "security"
  ],
  "icons": {
    "default": "images/extension-icon.png"
  },
  "branding": {
    "color": "#0c0e10",
    "theme": "dark"
  },
  "content": {
    "details": {
      "path": "README.md"
    },
    "license": {
      "path": "LICENSE"
    }
  },
  "links": {
    "getstarted": {
      "uri": "https://willibrandon.github.io/picket/generated/azure-devops/"
    },
    "learn": {
      "uri": "https://willibrandon.github.io/picket/"
    },
    "license": {
      "uri": "https://github.com/willibrandon/picket/blob/main/LICENSE"
    },
    "privacypolicy": {
      "uri": "https://github.com/willibrandon/picket/blob/main/azure-devops/PRIVACY.md"
    },
    "support": {
      "uri": "https://github.com/willibrandon/picket/issues"
    }
  },
  "repository": {
    "type": "git",
    "uri": "https://github.com/willibrandon/picket"
  },
  "files": [
    {
      "path": "README.md",
      "addressable": true
    },
    {
      "path": "LICENSE",
      "addressable": true
    },
    {
      "path": "CHANGELOG.md",
      "addressable": true
    },
    {
      "path": "COMPATIBILITY.md",
      "addressable": true
    },
    {
      "path": "PRIVACY.md",
      "addressable": true
    },
    {
      "path": "images/extension-icon.png",
      "addressable": true
    },
    {
      "path": "tasks/PicketScanV1"
    }
  ],
  "contributions": [
    {
      "id": "PicketScan",
      "type": "ms.vss-distributed-task.task",
      "targets": [
        "ms.vss-distributed-task.tasks"
      ],
      "properties": {
        "name": "tasks/PicketScanV1"
      }
    }
  ]
}
